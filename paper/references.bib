@misc{docs:claudecode2026cli,
  author       = {{Anthropic}},
  title        = {{Claude Code} CLI reference},
  howpublished = {Claude Code documentation},
  year         = {2026},
  note         = {Accessed 2026-05-28. Canonical URL on
